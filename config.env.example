# ============================================================
# Fleet Enrollment Configuration
# ============================================================
# Fill in ALL values below before distributing this package.
# Do not commit this file to version control after filling it in.
# ============================================================

# Tailscale pre-auth key
# Generate at: https://login.tailscale.com/admin/settings/keys
# Use an ephemeral key with tag:fleet-device for production.
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxx

# AWS S3 bucket name for log storage (no s3:// prefix)
S3_BUCKET=drone-fleet-assets

# Tailscale IP of the central EC2 management server
# Find this in the Tailscale admin console under Machines.
EC2_TAILSCALE_IP=100.64.x.x

# Fleet management SSH public key (full key, including type prefix and comment)
# Paste the entire one-line public key here.
FLEET_SSH_PUBLIC_KEY=ssh-ed25519 AAAA... fleet-management

# WinRM trusted IP range — the Tailscale mesh CGNAT subnet
# Do not change this unless your Tailscale network uses a different range.
WINRM_TRUSTED_RANGE=100.64.0.0/10
